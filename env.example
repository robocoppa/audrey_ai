# ─── Ollama ───
OLLAMA_BASE_URL=http://host.docker.internal:11434
ROUTER_MODEL=qwen2.5:1.5b
DEFAULT_TEMPERATURE=0.2
GPU_CONCURRENCY=1
MAX_DEEP_WORKERS=2

# ─── API Auth (leave empty to disable) ───
API_KEY=

# ─── Search ───
# "searxng" (local, no key) or "brave" (requires BRAVE_API_KEY)
SEARCH_BACKEND=searxng
BRAVE_API_KEY=

# ─── Tools ───
TOOLS_ENABLED=true

# ─── Display ───
EMIT_ROUTING_BANNER=true
EMIT_STATUS_UPDATES=true
LOG_LEVEL=INFO

# ─── Ports ───
ORCHESTRATOR_PORT=8000
SEARXNG_PORT=8080
TOOLS_PORT=8001
