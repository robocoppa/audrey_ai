# ─── Ollama ───
OLLAMA_BASE_URL=http://host.docker.internal:11434
ROUTER_MODEL=qwen3:4b
DEFAULT_TEMPERATURE=0.2
GPU_CONCURRENCY=1
MAX_DEEP_WORKERS=2
MAX_DEEP_WORKERS_CLOUD=3

# ─── API Auth (leave empty to disable) ───
API_KEY=

# ─── Search ───
# "searxng" (local, no key) or "brave" (requires BRAVE_API_KEY)
SEARCH_BACKEND=searxng
BRAVE_API_KEY=

# ─── Tools ───
TOOLS_ENABLED=true

# ─── Image Downscaling (VL workers) ───
# Clamps uploaded images before they hit cloud VL endpoints, which otherwise
# reject large multi-MB payloads with 400 'request body too large'.
# Long edge in pixels; images larger than this are resized.
AUDREY_IMG_MAX_EDGE=1024
# JPEG quality for re-encoded output
AUDREY_IMG_JPEG_QUALITY=85
# Raw byte threshold; images smaller than this are passed through untouched
AUDREY_IMG_DOWNSCALE_THRESHOLD=300000

# ─── Display ───
EMIT_ROUTING_BANNER=true
EMIT_STATUS_UPDATES=true
EMIT_TIMELINE_EVENTS=true
EMIT_TRUST_SIGNALS=true

# ─── Complexity Gate ───
COMPLEXITY_FORCE_DEEP=true
COMPLEXITY_TOKEN_THRESHOLD=500

# ─── Knowledge Server ───
EMBEDDING_MODEL=nomic-embed-text
EMBED_CONCURRENCY=8
# Parallel file ingestions during background scan
INGEST_CONCURRENCY=12
CHUNK_SIZE=3500
CHUNK_OVERLAP=500

# ─── Vision (image captioning during knowledge ingestion) ───
# Tune VISION_PROMPT for your domain. Examples:
#   Geology: "Describe this geological image. Identify the mineral, rock, or formation. Note color, luster, crystal structure, texture, and any visible labels."
#   Martial arts: "Describe this martial arts image. Identify the technique, position, or movement shown. Note body positioning and any labels."
#   General: leave empty to use the built-in default prompt
VISION_MODEL=qwen3-vl:32b
VISION_ENABLED=true
VISION_PROMPT=
# Skip files outside this byte range (icons/sprites or huge scans)
VISION_MIN_BYTES=10240
VISION_MAX_BYTES=20971520
# Concurrent vision calls (Ollama OLLAMA_NUM_PARALLEL must allow this many)
VISION_PARALLEL=2

# ─── Background Ingestion ───
AUTO_SCAN=true
# Seconds between periodic rescans (0 = scan on startup only)
RESCAN_INTERVAL=1800
# Quiet hours — no new scans start during this window (24h format, 0-23)
INGEST_QUIET_START=20
INGEST_QUIET_END=7

# ─── Ports ───
AUDREY_PORT=8000
SEARXNG_PORT=8081
TOOLS_PORT=8001
KNOWLEDGE_PORT=8002

# ─── Timezone ───
TZ=America/Denver

# ─── Logging ───
LOG_LEVEL=INFO
